// Zed keymap
//
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "unbind": {
            "ctrl-shift-up": "editor::SelectToStartOfParagraph",
            "ctrl-shift-down": "editor::SelectToEndOfParagraph",
            "ctrl-shift-left": "editor::SelectSmallerSyntaxNode",
            "ctrl-shift-right": "editor::SelectLargerSyntaxNode",
            "ctrl-shift-l": "editor::SelectAllMatches",
            "ctrl-shift-h": ["pane::DeploySearch", { "replace_enabled": true }],
            "ctrl-shift-j": "editor::JoinLines",
            "ctrl-q": "zed::Quit",
        },
    },
    {
        "context": "VimControl && !menu",
        "unbind": {
            "ctrl-q": "vim::ToggleVisualBlock",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-s": "workspace::SaveAll",
            "ctrl-shift-h": "workspace::ActivatePaneLeft",
            "ctrl-shift-l": "workspace::ActivatePaneRight",
            "ctrl-shift-k": "workspace::ActivatePaneUp",
            "ctrl-shift-j": "workspace::ActivatePaneDown",
            "ctrl-q e": "workspace::FocusCenterPane",
            "ctrl-q t": "terminal_panel::ToggleFocus",
            "ctrl-q p": "project_panel::ToggleFocus",
            "ctrl-q w": "multi_workspace::FocusWorkspaceSidebar",
            "ctrl-q o": "outline_panel::ToggleFocus",
            "ctrl-q g": "git_panel::ToggleFocus",
            "ctrl-q a": "agent::ToggleFocus",
            "ctrl-q c": "collab_panel::ToggleFocus",
            "ctrl-q b": "debug_panel::ToggleFocus",
            "ctrl-q d": "diagnostics::Deploy",
        },
    },
    {
        "context": "Workspace || Editor",
        "bindings": {
            "ctrl-t": "terminal_panel::Toggle",
        },
    },
    {
        "context": "ThreadSwitcher",
        // TODO: These bindings suck, Remember to recheck once feature is finished.
        "bindings": {
            "j": "agents_sidebar::ToggleThreadSwitcher",
            "down": "agents_sidebar::ToggleThreadSwitcher",
            "k": [
                "agents_sidebar::ToggleThreadSwitcher",
                { "select_last": true },
            ],
            "up": [
                "agents_sidebar::ToggleThreadSwitcher",
                { "select_last": true },
            ],
        },
    },

    // MD spesific sc
    {
        "context": "VimControl && !menu && extension == md",
        "use_key_equivalents": true,
        "bindings": {
            "j": [ "vim::Down", {"display_lines": true} ],
            "k": [ "vim::Up", {"display_lines": true} ]
        }
    },

    // *** VIM Editor ***
    {
        "context": "Editor && VimControl && !menu",
        "bindings": {
            "ctrl-w L": [
                "workspace::MoveItemToPaneInDirection",
                { "direction": "right" },
            ],
            "ctrl-w H": [
                "workspace::MoveItemToPaneInDirection",
                { "direction": "left" },
            ],
            "ctrl-w J": [
                "workspace::MoveItemToPaneInDirection",
                { "direction": "down" },
            ],
            "ctrl-w K": [
                "workspace::MoveItemToPaneInDirection",
                { "direction": "up" },
            ],

            "cmd-alt-1": [
                "workspace::MoveItemToPane",
                { "destination": 0, "focus": true, "clone": false },
            ],
            "cmd-alt-2": [
                "workspace::MoveItemToPane",
                { "destination": 1, "focus": true, "clone": false },
            ],
            "cmd-alt-3": [
                "workspace::MoveItemToPane",
                { "destination": 2, "focus": true, "clone": false },
            ],
            "cmd-alt-4": [
                "workspace::MoveItemToPane",
                { "destination": 3, "focus": true, "clone": false },
            ],
            "cmd-alt-5": [
                "workspace::MoveItemToPane",
                { "destination": 4, "focus": true, "clone": false },
            ],
            "cmd-alt-6": [
                "workspace::MoveItemToPane",
                { "destination": 5, "focus": true, "clone": false },
            ],
            "cmd-alt-7": [
                "workspace::MoveItemToPane",
                { "destination": 6, "focus": true, "clone": false },
            ],
            "cmd-alt-8": [
                "workspace::MoveItemToPane",
                { "destination": 7, "focus": true, "clone": false },
            ],
            "cmd-alt-9": [
                "workspace::MoveItemToPane",
                { "destination": 8, "focus": true, "clone": false },
            ],

            "alt-s": "editor::UnwrapSyntaxNode",
            "alt-k": "editor::MoveLineUp",
            "alt-j": "editor::MoveLineDown",
            "alt-w": "vim::NextSubwordStart",
            "alt-b": "vim::PreviousSubwordStart",
            "alt-e": "vim::NextSubwordEnd",
            "cmd-alt-k": "editor::AddSelectionAbove",
            "cmd-alt-j": "editor::AddSelectionBelow", // Insert cursor below
        },
    },
    {
        "context": "(Workspace && !Editor && !Terminal) || (Editor && VimControl)",
        "bindings": {
            // Global Leader key
            "space b n": "workspace::NewFile",
            "space y y": [
                "task::Spawn",
                { "task_name": "yazi", "reveal_target": "center" },
            ],
            "space s a": "agents_sidebar::ToggleThreadSwitcher",
            "space s p": [
                "projects::OpenRecent",
                { "create_new_window": false },
            ],
            "space s f": "file_finder::Toggle",
            "space b b": "pane::AlternateFile",
            "space b d": ["pane::CloseActiveItem", { "close_pinned": false }],
            "space b q": ["pane::CloseOtherItems", { "close_pinned": false }],
            "space b p": "pane::TogglePinTab",
            "space i h": "editor::ToggleInlayHints",
            "space g '": "editor::GoToHunk",
            "space g ;": "editor::GoToPreviousHunk",
            "space g h": "editor::ToggleSelectedDiffHunks",
            "space g S": "git::ToggleStaged",
            "space g r": "git::Restore",
            "space g s": "git::StageAndNext",
            "space g u": "git::UnstageAndNext",
            "space g b": "git::Blame",
            "space g d": "git::Diff",
            "space g c": "git::Commit",
            "space p": "editor::GoToDiagnostic",
            "space shift-p": "editor::GoToPreviousDiagnostic",
            "space h": "editor::Hover",
            "space space": "tab_switcher::OpenInActivePane",
            // Open markdown preview
            "space m p": "markdown::OpenPreview",
            "space m P": "markdown::OpenPreviewToTheSide",
            "space z": "workspace::ToggleCenteredLayout",
            "space d": "editor::DuplicateLineDown",
        },
    },
    // Which key, refer to https://github.com/zed-industries/zed/pull/43618
    {
        "context": "(VimControl && !menu)",
        "bindings": {
            "space": null, // Disable the default action vim::WrappingRight
        },
    },
    {
        "context": "vim_mode == visual",
        "bindings": {
            "v": "editor::SelectLargerSyntaxNode",
            "V": "editor::SelectSmallerSyntaxNode",
            "ctrl-s": "vim::PushAddSurrounds",
            "shift-x": "vim::Exchange",
        },
    },
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            "j k": "vim::NormalBefore",
            "k j": "vim::NormalBefore",
        },
    },
    {
        "context": "GitPanel > Editor && vim_mode==normal",
        "bindings": {
            "escape": "git_panel::FocusChanges",
        },
    },
    {
        "context": "GitGraph",
        "bindings": {
            "j": "menu::SelectNext",
            "k": "menu::SelectPrevious",
            "g g": "menu::SelectFirst",
            "G": "menu::SelectLast",
        },
    },
]
