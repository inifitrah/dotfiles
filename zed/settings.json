// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "agent_servers": {
        "opencode": {
            "type": "registry",
        },
    },
    "focus_follows_mouse": {
        "enabled": false,
    },
    "window_decorations": "client",
    "git": {
        "branch_picker": {
            "show_author_name": true,
        },
    },
    "proxy": "",
    "diff_view_style": "split",
    "cli_default_open_behavior": "new_window",
    "collaboration_panel": {
        "dock": "left",
    },
    "hover_popover_enabled": true,
    "hover_popover_delay": 1000,
    "hover_popover_hiding_delay": 1000,
    "hover_popover_sticky": true,
    "confirm_quit": true,
    "git_panel": {
        "dock": "left",
    },
    "context_servers": {
        "mcp-server-github": {
            "enabled": true,
            "remote": false,
            "settings": {},
        },
        "Roblox_Studio": {
            "enabled": true,
            "remote": false,
            "command": "/home/fitrah/.var/app/org.vinegarhq.Vinegar/data/vinegar/kombucha/bin/wine",
            "args": [
                "cmd.exe",
                "/c",
                "Z:\\home\\fitrah\\.var\\app\\org.vinegarhq.Vinegar\\data\\vinegar\\appdata\\Roblox\\mcp.bat",
            ],
            "env": {
                "WINEPREFIX": "/home/fitrah/.var/app/org.vinegarhq.Vinegar/data/vinegar/prefixes/studio",
            },
        },
    },
    "show_edit_predictions": false,
    "edit_predictions": {
        "provider": "none",
    },
    "agent": {
        "dock": "right",
        "tool_permissions": {
            "tools": {
                "mcp:Roblox_Studio:list_roblox_studios": {
                    "default": "allow",
                },
            },
        },
        "inline_assistant_model": {
            "provider": "copilot_chat",
            "model": "gpt-5.4-mini",
            "enable_thinking": false,
        },
        "default_profile": "write",
        "default_model": {
            "enable_thinking": true,
            "provider": "copilot_chat",
            "model": "claude-haiku-4.5",
        },
        "favorite_models": [],
        "model_parameters": [],
    },
    "toolbar": {
        "quick_actions": false,
        "agent_review": false,
        "code_actions": false,
        "breadcrumbs": true,
        "selections_menu": false,
    },
    "tabs": {
        "git_status": true,
    },
    "session": { "trust_all_worktrees": true },
    "title_bar": {
        "button_layout": "platform_default",
        "show_sign_in": true,
        "show_branch_name": false,
        "show_menus": false,
        "show_onboarding_banner": false,
        "show_project_items": false,
        "show_user_menu": true,
        "show_user_picture": true,
    },
    "tab_bar": {
        "show": true,
        "show_nav_history_buttons": true,
    },
    "vim": {
        "use_system_clipboard": "on_yank",
    },
    "vim_mode": true,
    "disable_ai": false,
    // "autosave": { "after_delay": { "milliseconds": 60000 } },
    "auto_install_extensions": { "html": true },
    "allow_rewrap": "anywhere",
    "bottom_dock_layout": "contained",
    "icon_theme": {
        "mode": "dark",
        "light": "Material Icon Theme",
        "dark": "Material Icon Theme",
    },
    "jsx_tag_auto_close": {
        "enabled": true,
    },
    "ui_font_size": 21,
    "buffer_font_size": 16,
    "theme": {
        "mode": "dark",
        "light": "GitHub Light",
        "dark": "GitHub Dark Default",
    },
    "theme_overrides": {
        "Aura Dark": {
            "text": "#dce0e5ff",
            "text.muted": "#a9afbcff",
            "text.placeholder": "#878a98ff",
            "text.disabled": "#878a98ff",
